                                           Height="180"
                                           Stretch="Uniform"/>
                                </StackPanel>
                            </Grid>

                            <Grid Visibility="{x:Bind ViewModel.AutoScanCounterVisibility, Mode=OneWay}">
                                <Rectangle x:Name="AutoScanPulseFlash" Fill="#609CDCF8" Opacity="0" RadiusX="12" RadiusY="12"/>
                                <Rectangle x:Name="AutoScanPulseLine" Height="8" Fill="#7AB8FF" VerticalAlignment="Top" Opacity="0" RadiusX="4" RadiusY="4" Margin="16,18,16,0">
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="AutoScanPulseLineTranslate" Y="-180"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                                    <Grid Width="240" Height="240">
                                        <Ellipse Width="224"
                                                 Height="224"
                                                 Stroke="#E8EEF8"
                                                 StrokeThickness="8"/>
                                        <Ellipse Width="220"
                                                 Height="220"
                                                 Stroke="{ThemeResource BorderBrush}"
                                                 StrokeThickness="1.5"/>
                                        <ProgressRing Visibility="{x:Bind ViewModel.AutoScanLoadingVisibility, Mode=OneWay}"
                                                      IsActive="True"
                                                      Width="220"
                                                      Height="220"
                                                      Foreground="{StaticResource BrandBlueBrush}"/>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind ViewModel.AutoScanScannedCount, Mode=OneWay}"
                                                       FontSize="116"
                                                       FontWeight="SemiBold"
                                                       Foreground="#0F2A53"
                                                       TextAlignment="Center"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,-10,0,0"/>
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{x:Bind ViewModel.AutoScanStateText, Mode=OneWay}" FontSize="14" Foreground="{StaticResource BrandBlueBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2" Margin="16,0,16,16">
                        <Button
                            Content="Stop Auto Scan"
                            Click="OnScanClicked"
                            HorizontalAlignment="Center"
                            Style="{StaticResource StopAutoScanButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid
            x:Name="SearchOverlayLayer"
            Grid.Row="0"
            Grid.RowSpan="2"
            Canvas.ZIndex="30"
            Background="{x:Null}"
            Visibility="Collapsed">
            <Border
                x:Name="SearchDropdownPanel"
                Width="{Binding ActualWidth, ElementName=SearchInputAnchor}"
                Style="{StaticResource BcrSearchDropdownPanelStyle}"
                PointerPressed="OnSearchDropdownPanelPointerPressed">
                <Grid>
                    <Grid x:Name="DefaultSearchPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Recent Searches" FontSize="13" FontWeight="SemiBold" />
                        <ListView
                            x:Name="RecentSearchesList"
                            Grid.Row="2"
                            MaxHeight="260"
                            Padding="0"
                            IsItemClickEnabled="True"
                            SelectionMode="None"
                            ItemClick="OnRecentSearchItemClick"
                            ItemsSource="{x:Bind ViewModel.RecentSearches, Mode=OneWay}">
                            <ListView.ItemContainerStyle>
                                <StaticResource ResourceKey="RecentSearchListViewItemStyle"/>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>

                    <Grid x:Name="AdvancedSearchPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Advanced Search" FontSize="13" FontWeight="SemiBold" />
                        <Grid Grid.Row="2" RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Spacing="8">
                                <TextBlock Text="Date" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CalendarDatePicker x:Name="AdvancedStartDatePicker" Grid.Column="0" HorizontalAlignment="Stretch" />
                                    <CalendarDatePicker x:Name="AdvancedEndDatePicker" Grid.Column="1" HorizontalAlignment="Stretch" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Today" Tag="Today" Height="30" Padding="10,2" Click="OnAdvancedRecentPresetClicked" />
                                    <Button Content="Within 3 days" Tag="Within 3 days" Height="30" Padding="10,2" Click="OnAdvancedRecentPresetClicked" />
                                    <Button Content="Within 7 days" Tag="Within 7 days" Height="30" Padding="10,2" Click="OnAdvancedRecentPresetClicked" />
                                </StackPanel>
                            </StackPanel>
                            <TextBox x:Name="AdvancedCompanyTextBox" Grid.Row="1" Header="Company" />
                            <TextBox x:Name="AdvancedNameTextBox" Grid.Row="2" Header="Name" />
                            <StackPanel Grid.Row="3" Spacing="8">
                                <TextBlock Text="Tag" />
                                <Border Background="Transparent" Padding="0,0,24,0">
                                    <ItemsRepeater ItemsSource="{x:Bind AdvancedTagFlowItems, Mode=OneWay}" VerticalAlignment="Top">
                                        <ItemsRepeater.Layout>
                                            <LinedFlowLayout MinItemSpacing="8" LineSpacing="8" ItemsStretch="None"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:TagFlowItem">
                                                <Grid HorizontalAlignment="Left">
                                                    <Border Background="{StaticResource BcrBrush.Surface}"
                                                            BorderBrush="{StaticResource BcrBrush.Border}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Height="34"
                                                            Padding="10,0">
                                                        <Grid ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{x:Bind Text}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="140"/>
                                                            <Button Grid.Column="1"
                                                                    Tag="{x:Bind Text}"
                                                                    MinWidth="20"
                                                                    Height="20"
                                                                    VerticalAlignment="Center"
                                                                    Padding="0"
                                                                    Click="OnRemoveAdvancedTagClicked">
                                                                <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </Border>
                                <Button Content="+ Add tag"
                                        Click="OnAddAdvancedTagClicked"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Height="34"
                                        MinWidth="100"
                                        HorizontalAlignment="Left"
                                        Padding="12,4"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Content="Clear" Height="32" Padding="16,4,16,4" FontSize="14" FontWeight="Normal" Click="OnAdvancedSearchClearClicked" />
                            <Button Content="Search" Style="{StaticResource PrimaryActionStyle}" Height="32" Padding="16,4,16,4" FontSize="14" FontWeight="Normal" Click="OnAdvancedSearchClicked" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

