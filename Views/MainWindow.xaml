                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid
                            Grid.Column="0"
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center">
                            <Ellipse
                                x:Name="ScannerReadyPulseRing"
                                Width="14"
                                Height="14"
                                Fill="{StaticResource BcrStatus.Ready}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5"
                                Visibility="{x:Bind ViewModel.ScannerReadyIndicatorVisibility, Mode=OneWay}">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="ScannerReadyPulseScale" ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse
                                Width="10"
                                Height="10"
                                Fill="{StaticResource BcrStatus.Ready}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.ScannerReadyIndicatorVisibility, Mode=OneWay}"/>
                            <Ellipse
                                Width="10"
                                Height="10"
                                Fill="{StaticResource BcrStatus.Offline}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.ScannerOfflineIndicatorVisibility, Mode=OneWay}"/>
                        </Grid>

                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind ViewModel.ScannerStatusText, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.ScannerReadyIndicatorVisibility, Mode=OneWay}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource BcrStatus.Ready}"
                                TextTrimming="CharacterEllipsis"/>
                            <TextBlock
                                Text="{x:Bind ViewModel.ScannerStatusText, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.ScannerOfflineIndicatorVisibility, Mode=OneWay}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                TextTrimming="CharacterEllipsis"/>
                            <TextBlock
