<Window
    x:Class="PlustekBCR.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:PlustekBCR.Views"
    xmlns:models="using:PlustekBCR.Models"
    mc:Ignorable="d"
    Title="Plustek AI BCR">
    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" AllowDrop="True" DragEnter="OnGlobalDragOver" DragOver="OnGlobalDragOver">
        <Grid.Resources>
            <!-- AI Toggle Active Animation (Shaking flask, scaling bounce, and sliding text) -->
            <Storyboard x:Name="ActivateAiStoryboard">
                <!-- Icon Scale Bounce -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AiIconScale" Storyboard.TargetProperty="ScaleX">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.25">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="0.95">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AiIconScale" Storyboard.TargetProperty="ScaleY">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1.25">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="0.95">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>

                <!-- Icon Shaking Wobble (Chemistry flask reaction) -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AiIconRotate" Storyboard.TargetProperty="Angle">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="-15">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="12">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="-9">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="6">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="-3">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>

                <!-- Icon Opacity Cross-Fade -->
                <DoubleAnimation Storyboard.TargetName="AiIconOff" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                <DoubleAnimation Storyboard.TargetName="AiIconOn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25"/>

                <!-- AI OFF Text Fade Out and Slide Up -->
                <DoubleAnimation Storyboard.TargetName="AiOffText" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                <DoubleAnimation Storyboard.TargetName="AiOffTextTranslate" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.25">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <!-- AI ON Text Fade In and Slide Up -->
                <DoubleAnimation Storyboard.TargetName="AiOnText" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AiOnTextTranslate" Storyboard.TargetProperty="Y">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="10"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <!-- AI Toggle Deactive Animation (Drop scale and slide down text) -->
            <Storyboard x:Name="DeactivateAiStoryboard">
                <!-- Icon Scale Drop -->
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AiIconScale" Storyboard.TargetProperty="ScaleX">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="0.85">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1.0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AiIconScale" Storyboard.TargetProperty="ScaleY">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="0.85">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="1.0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>

                <!-- Icon Opacity Cross-Fade -->
                <DoubleAnimation Storyboard.TargetName="AiIconOff" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25"/>
                <DoubleAnimation Storyboard.TargetName="AiIconOn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>

                <!-- AI ON Text Fade Out and Slide Down -->
                <DoubleAnimation Storyboard.TargetName="AiOnText" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                <DoubleAnimation Storyboard.TargetName="AiOnTextTranslate" Storyboard.TargetProperty="Y" To="10" Duration="0:0:0.25">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <!-- AI OFF Text Fade In and Slide Down -->
                <DoubleAnimation Storyboard.TargetName="AiOffText" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AiOffTextTranslate" Storyboard.TargetProperty="Y">
                    <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="-10"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <Storyboard x:Name="AutoScanPulseStoryboard">
                <DoubleAnimation Storyboard.TargetName="AutoScanPulseFlash" Storyboard.TargetProperty="Opacity" From="0" To="0.65" Duration="0:0:0.12" AutoReverse="True"/>
                <DoubleAnimation Storyboard.TargetName="AutoScanPulseLine" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.1"/>
                <DoubleAnimation Storyboard.TargetName="AutoScanPulseLineTranslate" Storyboard.TargetProperty="Y" From="-160" To="160" Duration="0:0:0.48"/>
                <DoubleAnimation Storyboard.TargetName="AutoScanPulseLine" Storyboard.TargetProperty="Opacity" To="0" BeginTime="0:0:0.38" Duration="0:0:0.18"/>
            </Storyboard>

            <Storyboard x:Name="ScannerReadyPulseStoryboard">
                <DoubleAnimation Storyboard.TargetName="ScannerReadyPulseScale" Storyboard.TargetProperty="ScaleX" From="1" To="1.55" Duration="0:0:1.15" AutoReverse="True" RepeatBehavior="Forever"/>
                <DoubleAnimation Storyboard.TargetName="ScannerReadyPulseScale" Storyboard.TargetProperty="ScaleY" From="1" To="1.55" Duration="0:0:1.15" AutoReverse="True" RepeatBehavior="Forever"/>
                <DoubleAnimation Storyboard.TargetName="ScannerReadyPulseRing" Storyboard.TargetProperty="Opacity" From="0.4" To="0.08" Duration="0:0:1.15" AutoReverse="True" RepeatBehavior="Forever"/>
            </Storyboard>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Canvas.ZIndex="20" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="HeaderScanButton" Grid.Column="0" Style="{StaticResource PrimaryActionStyle}" Click="OnScanClicked" HorizontalAlignment="Stretch" Margin="0,0,4,0" Height="52">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Data="M2.747 15a.75.75 0 0 1 .743.648l.007.102v3.502l.007.128a1.25 1.25 0 0 0 1.115 1.116l.128.006h3.5l.102.007a.75.75 0 0 1 0 1.486l-.102.007h-3.5l-.167-.005a2.75 2.75 0 0 1-2.578-2.57l-.005-.175V15.75l.007-.102A.75.75 0 0 1 2.747 15Zm18.5 0a.75.75 0 0 1 .743.648l.007.102v3.502a2.75 2.75 0 0 1-2.582 2.745l-.168.005h-3.5a.75.75 0 0 1-.102-1.493l.102-.007h3.5a1.25 1.25 0 0 0 1.244-1.122l.006-.128V15.75a.75.75 0 0 1 .75-.75Zm-8.992.5a.75.75 0 0 1 .102 1.493l-.102.007H7.75a.75.75 0 0 1-.102-1.493l.102-.007h4.505Zm3.995-4.25a.75.75 0 0 1 .102 1.493l-.102.007h-8.5a.75.75 0 0 1-.102-1.493l.102-.007h8.5ZM8.247 2a.75.75 0 0 1 .102 1.493l-.102.007h-3.5a1.25 1.25 0 0 0-1.243 1.122l-.007.128v3.502a.75.75 0 0 1-1.493.102l-.007-.102V4.75A2.75 2.75 0 0 1 4.58 2.005L4.747 2h3.5Zm11 0 .168.005a2.75 2.75 0 0 1 2.577 2.57l.005.175v3.502l-.007.102a.75.75 0 0 1-1.486 0l-.007-.102V4.75l-.006-.128a1.25 1.25 0 0 0-1.116-1.116l-.128-.006h-3.5l-.102-.007a.75.75 0 0 1 0-1.486L15.747 2h3.5ZM16.25 7a.75.75 0 0 1 .102 1.493l-.102.007h-8.5a.75.75 0 0 1-.102-1.493L7.75 7h8.5Z" Stretch="Uniform" Width="20" Height="20" Fill="White"/>
                            <TextBlock Text="Scan" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="HeaderImportButton" Grid.Column="1" Style="{StaticResource PrimaryActionStyle}" Click="OnImportClicked" HorizontalAlignment="Stretch" Margin="4,0,0,0" Height="52">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Data="M18.25 3.509a.75.75 0 1 0 0-1.5l-13-.004a.75.75 0 1 0 0 1.5l13 .004Zm-6.602 18.488.102.007a.75.75 0 0 0 .743-.649l.007-.101-.001-13.685 3.722 3.72a.75.75 0 0 0 .976.072l.085-.072a.75.75 0 0 0 .072-.977l-.073-.084-4.997-4.996a.75.75 0 0 0-.976-.073l-.085.072-5.003 4.997a.75.75 0 0 0 .976 1.134l.084-.073 3.719-3.713L11 21.254c0 .38.282.693.648.743Z" Stretch="Uniform" Width="20" Height="20" Fill="White"/>
                            <TextBlock Text="Import" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid x:Name="SearchRoot" Grid.Column="1" Width="600" MaxWidth="760" Height="44" Canvas.ZIndex="40" HorizontalAlignment="Left" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        x:Name="SearchScopeComboBox"
                        Style="{StaticResource BcrComboBoxStyle}"
                        Grid.Column="0"
                        Width="160"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Height="36"
                        PlaceholderText="????冗"
                        DropDownOpened="OnSearchScopeDropDownOpened"
                        DropDownClosed="OnSearchScopeDropDownClosed"
                        SelectionChanged="OnSearchScopeSelectionChanged"
                        ItemsSource="{x:Bind ViewModel.SearchScopes, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedSearchScope, Mode=TwoWay}" />

                    <Grid x:Name="SearchInputAnchor" Grid.Column="1">
                        <Border
                            x:Name="SearchBoxHost"
                            Height="36"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            PointerPressed="OnSearchBoxHostPointerPressed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="SearchPlaceholder"
                                    Grid.Column="0"
                                    Text="Search"
                                    Margin="12,0,8,0"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    IsHitTestVisible="False" />
                                <TextBox
                                    x:Name="HeaderSearchBox"
                                    Grid.Column="0"
                                    Style="{StaticResource InlineSearchTextBoxStyle}"
                                    Height="36"
                                    PlaceholderText=" "
                                    TextChanged="OnHeaderSearchBoxTextChanged"
                                    GotFocus="OnHeaderSearchBoxGotFocus"
                                    LostFocus="OnHeaderSearchBoxLostFocus"
                                    KeyDown="OnHeaderSearchBoxKeyDown" />
                                <Button Grid.Column="1" Style="{StaticResource SearchIconButtonStyle}" Click="OnOpenAdvancedSearchClicked" ToolTipService.ToolTip="?脤???">
                                    <FontIcon Glyph="&#xE71C;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Button>
                            </Grid>
                        </Border>

                        <Border
                            x:Name="DateSearchBoxHost"
                            Height="44"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            Visibility="Collapsed">
                            <Grid ColumnSpacing="4" Padding="4,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>

                                <CalendarDatePicker
                                    x:Name="HeaderStartDatePicker"
                                    Grid.Column="0"
                                    Height="34"
                                    PlaceholderText="Start"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch" />
                                <CalendarDatePicker
                                    x:Name="HeaderEndDatePicker"
                                    Grid.Column="1"
                                    Height="34"
                                    PlaceholderText="End"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch" />
                                <Button Grid.Column="2" Style="{StaticResource SearchIconButtonStyle}" Click="OnHeaderDateSearchClicked" ToolTipService.ToolTip="Search date range">
                                    <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Button>
                                <Button Grid.Column="3" Style="{StaticResource SearchIconButtonStyle}" Click="OnHeaderDateClearClicked" ToolTipService.ToolTip="Clear date filter">
                                    <FontIcon Glyph="&#xE711;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Button>
                                <Button Grid.Column="4" Style="{StaticResource SearchIconButtonStyle}" Click="OnOpenAdvancedSearchClicked" ToolTipService.ToolTip="Advanced search">
                                    <FontIcon Glyph="&#xE71C;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="0">
                    <ToggleButton x:Name="HeaderAiButton" Style="{StaticResource AiToggleButtonStyle}" IsChecked="{x:Bind ViewModel.IsAiEnabled, Mode=TwoWay}" Checked="OnAiChecked" Unchecked="OnAiUnchecked" Margin="0,0,0,0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Overlayed Icons inside a single Grid to allow smooth cross-fade and joint transformations -->
                            <Grid x:Name="AiIconContainer" Width="20" Height="20" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="AiIconScale" ScaleX="1" ScaleY="1"/>
                                        <RotateTransform x:Name="AiIconRotate" Angle="0"/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
