<Page
    x:Class="PlustekBCR.Views.AllCardsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PlustekBCR.Models"
    xmlns:viewmodels="using:PlustekBCR.ViewModels"
    xmlns:controls="using:PlustekBCR.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedCardsSource" 
                              IsSourceGrouped="True" 
                              Source="{x:Bind ViewModel.GroupedCards, Mode=OneWay}"/>
    </Page.Resources>

    <Grid Background="Transparent" PointerPressed="OnOverlayClicked">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="0"
            Grid.Column="0"
            Margin="24,16,24,0"
            Padding="12,8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Visibility="{x:Bind ViewModel.MainViewModel.IsSearchActive, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{Binding [View.AllCards.SearchResults]}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.SearchResultSummary, Mode=OneWay}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="1" Content="{Binding [Button.Clear]}" Height="30" Padding="12,2" Click="OnClearSearchClicked"/>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Visibility="{x:Bind ViewModel.ShowCardsContent, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <GridView 
                x:Name="CardGridView"
                Visibility="{x:Bind ViewModel.MainViewModel.IsGridView, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                ItemsSource="{x:Bind GroupedCardsSource.View, Mode=OneWay}"
                SelectionMode="None"
                IsItemClickEnabled="True"
                ItemClick="OnCardClick"
                DoubleTapped="OnCardDoubleTapped"
                Background="Transparent"
                Padding="24,24,24,48"
                ItemContainerStyle="{StaticResource BusinessCardItemStyle}"
                Canvas.ZIndex="10">
            
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:BusinessCard">
                    <Grid x:Name="CardRoot" Width="240" Margin="24,8,8,24" CornerRadius="12" 
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                          BorderThickness="1"
                          PointerEntered="Card_PointerEntered"
                          PointerExited="Card_PointerExited"
                          Translation="0,0,16">
                        <Grid.ContextFlyout>
                            <MenuFlyout MenuFlyoutPresenterStyle="{StaticResource BcrTagMenuFlyoutPresenterStyle}">
                                <MenuFlyoutItem Text="{Binding [Button.ViewDetails]}" Click="OnViewDetailsContextClicked">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE7B3;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSubItem Text="{Binding [Main.Navigation.Export]}">
                                    <MenuFlyoutSubItem.Icon>
                                        <FontIcon Glyph="&#xE74E;"/>
                                    </MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem Text="{Binding [Button.ExportCsv]}" Click="OnExportCsvContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE9D5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="{Binding [Button.ExportTxt]}" Click="OnExportTxtContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyoutSubItem>
                                <MenuFlyoutItem Text="{Binding [Button.Delete]}" Click="OnDeleteContextClicked" Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <Grid.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.3"/>
                        </Grid.ScaleTransition>
                        <Grid.TranslationTransition>
                            <Vector3Transition Duration="0:0:0.3"/>
                        </Grid.TranslationTransition>
                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>
                        <StackPanel Padding="12" Spacing="8">
                            <!-- Thumbnail Area -->
                            <Border x:Name="GridCardThumbnailHost" Height="140" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                <Image Source="{x:Bind FrontImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Business Card Info -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind FullName, Mode=OneWay}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind JobTitle, Mode=OneWay}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind JobTitle, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                            </Grid>
                            <TextBlock Text="{x:Bind CompanyName, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>

                            <!-- Status Badge -->
                            <Grid HorizontalAlignment="Left">
                                <Border Style="{StaticResource BcrStatusBadgeBorderStyle}" Background="{x:Bind Status, Converter={StaticResource StatusToBackgroundBrushConverter}, Mode=OneWay}"/>
                                <StackPanel Style="{StaticResource BcrStatusBadgeContentStyle}">
                                    <ProgressRing Style="{StaticResource BcrStatusBadgeProgressRingStyle}"
                                                  Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}" 
                                                  Visibility="{x:Bind Status, Converter={StaticResource StatusToProgressVisibilityConverter}, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind Status, Converter={StaticResource StatusToStringConverter}, Mode=OneWay}" 
                                               Style="{StaticResource BcrStatusBadgeTextSmallStyle}"
                                               Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}"
                                               />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>

            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <StaticResource ResourceKey="BusinessCardGridGroupHeaderItemStyle"/>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="viewmodels:CardGroup">
                            <Grid Margin="24,24,0,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Path Data="M17.75 3A3.25 3.25 0 0 1 21 6.25v11.5A3.25 3.25 0 0 1 17.75 21H6.25A3.25 3.25 0 0 1 3 17.75V6.25A3.25 3.25 0 0 1 6.25 3h11.5Zm1.75 5.5h-15v9.25c0 .966.784 1.75 1.75 1.75h11.5a1.75 1.75 0 0 0 1.75-1.75V8.5Zm-11.75 6a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm-4.25-4a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm1.5-6H6.25A1.75 1.75 0 0 0 4.5 6.25V7h15v-.75a1.75 1.75 0 0 0-1.75-1.75Z" 
                                          Stretch="Uniform" Width="14" Height="14" Fill="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Key}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>
            </GridView>

            <!-- List View Mode -->
            <ListView
                x:Name="CardListView"
                Visibility="{x:Bind ViewModel.MainViewModel.IsGridView, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"
                ItemsSource="{x:Bind GroupedCardsSource.View, Mode=OneWay}"
                SelectionMode="None"
                IsItemClickEnabled="True"
                ItemClick="OnCardClick"
                DoubleTapped="OnCardDoubleTapped"
                Background="Transparent"
                Padding="24,24,24,48"
                Canvas.ZIndex="10">

            <ListView.ItemContainerStyle>
                <StaticResource ResourceKey="BusinessCardListItemStyle"/>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:BusinessCard">
                    <Grid x:Name="ListCardRoot" Padding="12,8,12,8" Background="Transparent">
                        <Grid.ContextFlyout>
                            <MenuFlyout MenuFlyoutPresenterStyle="{StaticResource BcrTagMenuFlyoutPresenterStyle}">
                                <MenuFlyoutItem Text="{Binding [Button.ViewDetails]}" Click="OnViewDetailsContextClicked">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE7B3;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSubItem Text="{Binding [Main.Navigation.Export]}">
                                    <MenuFlyoutSubItem.Icon>
                                        <FontIcon Glyph="&#xE74E;"/>
                                    </MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem Text="{Binding [Button.ExportCsv]}" Click="OnExportCsvContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE9D5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="{Binding [Button.ExportTxt]}" Click="OnExportTxtContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyoutSubItem>
                                <MenuFlyoutItem Text="{Binding [Button.Delete]}" Click="OnDeleteContextClicked" Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Thumbnail Area -->
                        <Border x:Name="ListCardThumbnailHost" Grid.Column="0" Width="80" Height="50" Margin="0,0,16,0" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                            <Image Source="{x:Bind FrontImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Business Card Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind FullName, Mode=OneWay}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind JobTitle, Mode=OneWay}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind JobTitle, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                <TextBlock Text="{x:Bind CompanyName, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Visibility="{x:Bind CompanyName, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Contact Info Summary (Optional for List View) -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <!-- Status Badge -->
                            <Grid HorizontalAlignment="Right">
                                <Border Style="{StaticResource BcrStatusBadgeBorderStyle}" Background="{x:Bind Status, Converter={StaticResource StatusToBackgroundBrushConverter}, Mode=OneWay}"/>
                                <StackPanel Style="{StaticResource BcrStatusBadgeContentStyle}">
                                    <ProgressRing Style="{StaticResource BcrStatusBadgeProgressRingStyle}"
                                                  Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}" 
                                                  Visibility="{x:Bind Status, Converter={StaticResource StatusToProgressVisibilityConverter}, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind Status, Converter={StaticResource StatusToStringConverter}, Mode=OneWay}" 
                                               Style="{StaticResource BcrStatusBadgeTextStyle}"
                                               Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}"
                                               />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <StaticResource ResourceKey="BusinessCardListGroupHeaderItemStyle"/>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="viewmodels:CardGroup">
                            <Grid Margin="24,24,0,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Path Data="M17.75 3A3.25 3.25 0 0 1 21 6.25v11.5A3.25 3.25 0 0 1 17.75 21H6.25A3.25 3.25 0 0 1 3 17.75V6.25A3.25 3.25 0 0 1 6.25 3h11.5Zm1.75 5.5h-15v9.25c0 .966.784 1.75 1.75 1.75h11.5a1.75 1.75 0 0 0 1.75-1.75V8.5Zm-11.75 6a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm-4.25-4a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm1.5-6H6.25A1.75 1.75 0 0 0 4.5 6.25V7h15v-.75a1.75 1.75 0 0 0-1.75-1.75Z" 
                                          Stretch="Uniform" Width="14" Height="14" Fill="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Key}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            </ListView>
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Canvas.ZIndex="11"
            Visibility="{x:Bind ViewModel.ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="32">
                <Image Source="ms-appx:///Assets/scanner_illustration.png"
                       Width="400"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding [Empty.FirstCard.Title]}"
                               Style="{ThemeResource TitleLargeTextBlockStyle}"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding [Empty.FirstCard.Description]}"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="400"/>
                </StackPanel>

                <Button x:Name="EmptyStateScanButton"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.MainViewModel.ScanCommand}"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Data="M2.747 15a.75.75 0 0 1 .743.648l.007.102v3.502l.007.128a1.25 1.25 0 0 0 1.115 1.116l.128.006h3.5l.102.007a.75.75 0 0 1 0 1.486l-.102.007h-3.5l-.167-.005a2.75 2.75 0 0 1-2.578-2.57l-.005-.175V15.75l.007-.102A.75.75 0 0 1 2.747 15Zm18.5 0a.75.75 0 0 1 .743.648l.007.102v3.502a2.75 2.75 0 0 1-2.582 2.745l-.168.005h-3.5a.75.75 0 0 1-.102-1.493l.102-.007h3.5a1.25 1.25 0 0 0 1.244-1.122l.006-.128V15.75a.75.75 0 0 1 .75-.75Zm-8.992.5a.75.75 0 0 1 .102 1.493l-.102.007H7.75a.75.75 0 0 1-.102-1.493l.102-.007h4.505Zm3.995-4.25a.75.75 0 0 1 .102 1.493l-.102.007h-8.5a.75.75 0 0 1-.102-1.493l.102-.007h8.5ZM8.247 2a.75.75 0 0 1 .102 1.493l-.102.007h-3.5a1.25 1.25 0 0 0-1.243 1.122l-.007.128v3.502a.75.75 0 0 1-1.493.102l-.007-.102V4.75A2.75 2.75 0 0 1 4.58 2.005L4.747 2h3.5Zm11 0 .168.005a2.75 2.75 0 0 1 2.577 2.57l.005.175v3.502l-.007.102a.75.75 0 0 1-1.486 0l-.007-.102V4.75l-.006-.128a1.25 1.25 0 0 0-1.116-1.116l-.128-.006h-3.5l-.102-.007a.75.75 0 0 1 0-1.486L15.747 2h3.5ZM16.25 7a.75.75 0 0 1 .102 1.493l-.102.007h-8.5a.75.75 0 0 1-.102-1.493L7.75 7h8.5Z"
                              Stretch="Uniform" Width="16" Height="16" Fill="{Binding Foreground, ElementName=EmptyStateScanButton}"/>
                        <TextBlock Text="{Binding [Button.Scan]}" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Canvas.ZIndex="11"
            IsHitTestVisible="False"
            Visibility="{x:Bind ViewModel.HasNoSearchResults, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="{Binding [View.AllCards.NoResults.Title]}" FontSize="18" FontWeight="SemiBold" TextAlignment="Center"/>
                <TextBlock Text="{Binding [View.AllCards.NoResults.Description]}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Overlay for closing sidebar -->
        <Grid x:Name="Overlay" 
              Grid.Row="1"
              Grid.Column="0"
              Background="Transparent" 
              Visibility="{x:Bind ViewModel.IsSidebarOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
              IsHitTestVisible="False"
              Canvas.ZIndex="5"/>

        <!-- Grid Splitter (Custom Thumb) -->
        <Thumb x:Name="SidebarSplitter"
               Grid.Row="1"
               Grid.Column="1"
               Width="8"
               Background="Transparent"
               DragDelta="OnSidebarSplitterDragDelta"
               PointerEntered="SidebarSplitter_PointerEntered"
               PointerExited="SidebarSplitter_PointerExited"
               Visibility="{x:Bind ViewModel.IsSidebarOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
               Canvas.ZIndex="15" />

        <!-- Sidebar -->
        <Border x:Name="Sidebar" 
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="2"
                Width="720" 
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{x:Bind ViewModel.IsSidebarOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                SizeChanged="OnSidebarSizeChanged"
                Canvas.ZIndex="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button x:Name="SidebarFocusSink"
                        Width="1"
                        Height="1"
                        Opacity="0"
                        IsTabStop="True"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="-100,-100,0,0"/>

                <!-- Header with Close Button Removed -->

                <!-- Sidebar Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24,24,24,48" 
                          CornerRadius="12" 
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                          BorderThickness="1"
                          PointerPressed="OnSidebarContentPointerPressed"
                          Translation="0,0,16">
                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>
                        <StackPanel Spacing="24" Padding="24">
                        <!-- Thumbnail area ??shows front only when narrow, front+back when wide -->
                        <Grid x:Name="CardImagesGrid" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition x:Name="BackImageColumn" Width="0"/>
                            </Grid.ColumnDefinitions>

                            <!-- Front Image -->
                            <Border x:Name="SidebarFrontImageHost"
                                    Grid.Column="0"
                                    Height="200"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="12">
                                <Image x:Name="SidebarFrontImage"
                                       Source="{x:Bind ViewModel.SelectedCard.FrontImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <!-- Back Image (column width controlled by SidebarSizeChanged; border hidden when no data) -->
                            <Border x:Name="SidebarBackImageBorder"
                                    Grid.Column="1"
                                    Height="200"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="12"
                                    Visibility="{x:Bind ViewModel.SelectedCard.BackImageData, Converter={StaticResource ByteArrayToVisibilityConverter}, Mode=OneWay}">
                                <Image x:Name="SidebarBackImage"
                                       Source="{x:Bind ViewModel.SelectedCard.BackImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Personal Group -->
                        <StackPanel Spacing="8">
                            <Grid>
                                    <Border Background="Transparent"
                                            Padding="0,4"
                                            Tapped="OnDetailFieldTapped"
                                            Tag="Name"
                                            Visibility="{x:Bind ViewModel.IsEditingName, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind ViewModel.SelectedCard.FullName, Mode=OneWay}"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       TextWrapping="WrapWholeWords"
                                                       Visibility="{x:Bind ViewModel.HasDetailNameText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,8,0,0"
                                                       Text="{x:Bind ViewModel.DetailNameKanaText, Mode=OneWay}"
                                                       FontSize="13"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="WrapWholeWords"
                                                       VerticalAlignment="Top"
                                                       Visibility="{x:Bind ViewModel.HasDetailNameKanaText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                            <TextBlock Text="{Binding [Placeholder.ClickToEnterName]}"
                                                       Style="{StaticResource BcrEditableFieldPlaceholderTextStyle}"
                                                       FontSize="24"
                                                       Visibility="{x:Bind ViewModel.HasDetailNameText, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"/>
                                        </Grid>
                                    </Border>
                                    <Grid x:Name="NameEditContainer"
                                          Visibility="{x:Bind ViewModel.IsEditingName, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
