<Page
    x:Class="PlustekBCR.Views.AllCardsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PlustekBCR.Models"
    xmlns:viewmodels="using:PlustekBCR.ViewModels"
    xmlns:controls="using:PlustekBCR.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedCardsSource" 
                              IsSourceGrouped="True" 
                              Source="{x:Bind ViewModel.GroupedCards, Mode=OneWay}"/>
    </Page.Resources>

    <Grid Background="Transparent" PointerPressed="OnOverlayClicked">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="0"
            Grid.Column="0"
            Margin="24,16,24,0"
            Padding="12,8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Visibility="{x:Bind ViewModel.MainViewModel.IsSearchActive, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Search results" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.SearchResultSummary, Mode=OneWay}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Clear" Height="30" Padding="12,2" Click="OnClearSearchClicked"/>
            </Grid>
        </Border>

        <GridView 
            x:Name="CardGridView"
            Grid.Row="1"
            Grid.Column="0"
            Visibility="{x:Bind ViewModel.MainViewModel.IsGridView, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
            ItemsSource="{x:Bind GroupedCardsSource.View, Mode=OneWay}"
            SelectionMode="None"
            IsItemClickEnabled="True"
            ItemClick="OnCardClick"
            DoubleTapped="OnCardDoubleTapped"
            Background="Transparent"
            Padding="24,24,24,48"
            ItemContainerStyle="{StaticResource BusinessCardItemStyle}"
            Canvas.ZIndex="10">
            
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:BusinessCard">
                    <Grid x:Name="CardRoot" Width="240" Margin="24,8,8,24" CornerRadius="12" 
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                          BorderThickness="1"
                          PointerEntered="Card_PointerEntered"
                          PointerExited="Card_PointerExited"
                          Translation="0,0,16">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="View Details" Click="OnViewDetailsContextClicked">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE7B3;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSubItem Text="Export">
                                    <MenuFlyoutSubItem.Icon>
                                        <FontIcon Glyph="&#xE74E;"/>
                                    </MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem Text="Export as .csv" Click="OnExportCsvContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE9D5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Export as .txt" Click="OnExportTxtContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyoutSubItem>
                                <MenuFlyoutItem Text="Delete" Click="OnDeleteContextClicked" Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <Grid.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.3"/>
                        </Grid.ScaleTransition>
                        <Grid.TranslationTransition>
                            <Vector3Transition Duration="0:0:0.3"/>
                        </Grid.TranslationTransition>
                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>
                        <StackPanel Padding="12" Spacing="8">
                            <!-- Thumbnail Area -->
                            <Border x:Name="GridCardThumbnailHost" Height="140" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                <Image Source="{x:Bind FrontImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Business Card Info -->
                            <TextBlock Text="{x:Bind FullName, Mode=OneWay}" FontSize="18" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind CompanyName, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>

                            <!-- Status Badge -->
                            <Grid HorizontalAlignment="Left">
                                <Border Style="{StaticResource BcrStatusBadgeBorderStyle}" Background="{x:Bind Status, Converter={StaticResource StatusToBackgroundBrushConverter}, Mode=OneWay}"/>
                                <StackPanel Style="{StaticResource BcrStatusBadgeContentStyle}">
                                    <ProgressRing Style="{StaticResource BcrStatusBadgeProgressRingStyle}"
                                                  Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}" 
                                                  Visibility="{x:Bind Status, Converter={StaticResource StatusToProgressVisibilityConverter}, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind Status, Converter={StaticResource StatusToStringConverter}, Mode=OneWay}" 
                                               Style="{StaticResource BcrStatusBadgeTextSmallStyle}"
                                               Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}"
                                               />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>

            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <StaticResource ResourceKey="BusinessCardGridGroupHeaderItemStyle"/>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="viewmodels:CardGroup">
                            <Grid Margin="24,24,0,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Path Data="M17.75 3A3.25 3.25 0 0 1 21 6.25v11.5A3.25 3.25 0 0 1 17.75 21H6.25A3.25 3.25 0 0 1 3 17.75V6.25A3.25 3.25 0 0 1 6.25 3h11.5Zm1.75 5.5h-15v9.25c0 .966.784 1.75 1.75 1.75h11.5a1.75 1.75 0 0 0 1.75-1.75V8.5Zm-11.75 6a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm-4.25-4a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm1.5-6H6.25A1.75 1.75 0 0 0 4.5 6.25V7h15v-.75a1.75 1.75 0 0 0-1.75-1.75Z" 
                                          Stretch="Uniform" Width="14" Height="14" Fill="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Key}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>
        </GridView>

        <!-- List View Mode -->
        <ListView
            x:Name="CardListView"
            Grid.Row="1"
            Grid.Column="0"
            Visibility="{x:Bind ViewModel.MainViewModel.IsGridView, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"
            ItemsSource="{x:Bind GroupedCardsSource.View, Mode=OneWay}"
            SelectionMode="None"
            IsItemClickEnabled="True"
            ItemClick="OnCardClick"
            DoubleTapped="OnCardDoubleTapped"
            Background="Transparent"
            Padding="24,24,24,48"
            Canvas.ZIndex="10">

            <ListView.ItemContainerStyle>
                <StaticResource ResourceKey="BusinessCardListItemStyle"/>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:BusinessCard">
                    <Grid x:Name="ListCardRoot" Padding="12,8,12,8" Background="Transparent">
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="View Details" Click="OnViewDetailsContextClicked">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE7B3;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSubItem Text="Export">
                                    <MenuFlyoutSubItem.Icon>
                                        <FontIcon Glyph="&#xE74E;"/>
                                    </MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem Text="Export as .csv" Click="OnExportCsvContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE9D5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Export as .txt" Click="OnExportTxtContextClicked">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE8A5;"/>
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyoutSubItem>
                                <MenuFlyoutItem Text="Delete" Click="OnDeleteContextClicked" Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Thumbnail Area -->
                        <Border x:Name="ListCardThumbnailHost" Grid.Column="0" Width="80" Height="50" Margin="0,0,16,0" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                            <Image Source="{x:Bind FrontImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Business Card Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind FullName, Mode=OneWay}" FontSize="18" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                <TextBlock Text="{x:Bind CompanyName, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Visibility="{x:Bind CompanyName, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Contact Info Summary (Optional for List View) -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <!-- Status Badge -->
                            <Grid HorizontalAlignment="Right">
                                <Border Style="{StaticResource BcrStatusBadgeBorderStyle}" Background="{x:Bind Status, Converter={StaticResource StatusToBackgroundBrushConverter}, Mode=OneWay}"/>
                                <StackPanel Style="{StaticResource BcrStatusBadgeContentStyle}">
                                    <ProgressRing Style="{StaticResource BcrStatusBadgeProgressRingStyle}"
                                                  Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}" 
                                                  Visibility="{x:Bind Status, Converter={StaticResource StatusToProgressVisibilityConverter}, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind Status, Converter={StaticResource StatusToStringConverter}, Mode=OneWay}" 
                                               Style="{StaticResource BcrStatusBadgeTextStyle}"
                                               Foreground="{x:Bind Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}"
                                               />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <StaticResource ResourceKey="BusinessCardListGroupHeaderItemStyle"/>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="viewmodels:CardGroup">
                            <Grid Margin="24,24,0,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Path Data="M17.75 3A3.25 3.25 0 0 1 21 6.25v11.5A3.25 3.25 0 0 1 17.75 21H6.25A3.25 3.25 0 0 1 3 17.75V6.25A3.25 3.25 0 0 1 6.25 3h11.5Zm1.75 5.5h-15v9.25c0 .966.784 1.75 1.75 1.75h11.5a1.75 1.75 0 0 0 1.75-1.75V8.5Zm-11.75 6a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm-4.25-4a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm1.5-6H6.25A1.75 1.75 0 0 0 4.5 6.25V7h15v-.75a1.75 1.75 0 0 0-1.75-1.75Z" 
                                          Stretch="Uniform" Width="14" Height="14" Fill="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Key}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
        </ListView>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Canvas.ZIndex="11"
            IsHitTestVisible="False"
            Visibility="{x:Bind ViewModel.HasNoSearchResults, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="No matching business cards" FontSize="18" FontWeight="SemiBold" TextAlignment="Center"/>
                <TextBlock Text="Clear search conditions to return to all cards." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Overlay for closing sidebar -->
        <Grid x:Name="Overlay" 
              Grid.Row="1"
              Grid.Column="0"
              Background="Transparent" 
              Visibility="{x:Bind ViewModel.IsSidebarOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
              PointerPressed="OnOverlayClicked"
              Canvas.ZIndex="5"/>

        <!-- Grid Splitter (Custom Thumb) -->
        <Thumb x:Name="SidebarSplitter"
               Grid.Row="1"
               Grid.Column="1"
               Width="8"
               Background="Transparent"
               DragDelta="OnSidebarSplitterDragDelta"
               PointerEntered="SidebarSplitter_PointerEntered"
               PointerExited="SidebarSplitter_PointerExited"
               Visibility="{x:Bind ViewModel.IsSidebarOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
               Canvas.ZIndex="15" />

        <!-- Sidebar -->
        <Border x:Name="Sidebar" 
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="2"
                Width="720" 
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{x:Bind ViewModel.IsSidebarOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                SizeChanged="OnSidebarSizeChanged"
                Canvas.ZIndex="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button x:Name="SidebarFocusSink"
                        Width="1"
                        Height="1"
                        Opacity="0"
                        IsTabStop="True"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="-100,-100,0,0"/>

                <!-- Header with Close Button Removed -->

                <!-- Sidebar Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24,24,24,48" 
                          CornerRadius="12" 
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                          BorderThickness="1"
                          PointerPressed="OnSidebarContentPointerPressed"
                          Translation="0,0,16">
                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>
                        <StackPanel Spacing="24" Padding="24">
                        <!-- Thumbnail area ??shows front only when narrow, front+back when wide -->
                        <Grid x:Name="CardImagesGrid" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition x:Name="BackImageColumn" Width="0"/>
                            </Grid.ColumnDefinitions>

                            <!-- Front Image -->
                            <Border x:Name="SidebarFrontImageHost"
                                    Grid.Column="0"
                                    Height="200"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="12">
                                <Image x:Name="SidebarFrontImage"
                                       Source="{x:Bind ViewModel.SelectedCard.FrontImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>

                            <!-- Back Image (column width controlled by SidebarSizeChanged; border hidden when no data) -->
                            <Border x:Name="SidebarBackImageBorder"
                                    Grid.Column="1"
                                    Height="200"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="12"
                                    Visibility="{x:Bind ViewModel.SelectedCard.BackImageData, Converter={StaticResource ByteArrayToVisibilityConverter}, Mode=OneWay}">
                                <Image x:Name="SidebarBackImage"
                                       Source="{x:Bind ViewModel.SelectedCard.BackImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Personal Group -->
                        <StackPanel Spacing="8">
                            <Grid>
                                    <Border Background="Transparent"
                                            Padding="0,4"
                                            Tapped="OnDetailFieldTapped"
                                            Tag="Name"
                                            Visibility="{x:Bind ViewModel.IsEditingName, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}">
                                        <TextBlock Text="{x:Bind ViewModel.SelectedCard.FullName, Mode=OneWay}" FontSize="24" FontWeight="Bold" TextWrapping="WrapWholeWords"/>
                                    </Border>
                                    <Grid x:Name="NameEditContainer"
                                          Visibility="{x:Bind ViewModel.IsEditingName, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{x:Bind ViewModel.SelectedCard.LastName, Mode=TwoWay}"
                                                 PlaceholderText="Last name"
                                                 Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                        <TextBox Grid.Column="2"
                                                 Text="{x:Bind ViewModel.SelectedCard.FirstName, Mode=TwoWay}"
                                                 PlaceholderText="First name"
                                                 Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                        <TextBox Grid.Column="0"
                                                 Text="{x:Bind ViewModel.SelectedCard.FirstName, Mode=TwoWay}"
                                                 PlaceholderText="First name"
                                                 Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                        <TextBox Grid.Column="2"
                                                 Text="{x:Bind ViewModel.SelectedCard.LastName, Mode=TwoWay}"
                                                 PlaceholderText="Last name"
                                                 Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                    </Grid>
                            </Grid>

                            <controls:EditableField Text="{x:Bind ViewModel.SelectedCard.CompanyName, Mode=TwoWay}"
                                                    EditStarted="OnSimpleFieldEditStarted"
                                                    PlaceholderText="Click to enter company"
                                                    FontSize="14"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Grid>
                                    <Border Background="Transparent"
                                            Padding="0,4"
                                            Tapped="OnDetailFieldTapped"
                                            Tag="Department"
                                            Visibility="{x:Bind ViewModel.IsEditingDepartment, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}">
                                        <Grid>
                                            <TextBlock Text="{x:Bind ViewModel.SelectedCard.DepartmentFull, Mode=OneWay}"
                                                       FontSize="14"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="WrapWholeWords"
                                                       Visibility="{x:Bind ViewModel.HasDetailDepartmentText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                            <TextBlock Text="Click to enter department"
                                                       Style="{StaticResource BcrEditableFieldPlaceholderTextStyle}"
                                                       FontSize="14"
                                                       Visibility="{x:Bind ViewModel.HasDetailDepartmentText, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="DepartmentEditContainer"
                                                Spacing="6"
                                                Visibility="{x:Bind ViewModel.IsEditingDepartment, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <TextBox Text="{x:Bind ViewModel.SelectedCard.Department1, Mode=TwoWay}"
                                                 PlaceholderText="Department 1"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                        <TextBox Text="{x:Bind ViewModel.SelectedCard.Department2, Mode=TwoWay}"
                                                 PlaceholderText="Department 2"
                                                 Visibility="{x:Bind ViewModel.ShowDepartment2, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                        <TextBox Text="{x:Bind ViewModel.SelectedCard.Department3, Mode=TwoWay}"
                                                 PlaceholderText="Department 3"
                                                 Visibility="{x:Bind ViewModel.ShowDepartment3, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                        <TextBox Text="{x:Bind ViewModel.SelectedCard.Department4, Mode=TwoWay}"
                                                 PlaceholderText="Department 4"
                                                 Visibility="{x:Bind ViewModel.ShowDepartment4, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                 LosingFocus="OnCompositeFieldLosingFocus"/>
                                        <Button Content="+"
                                                Width="40"
                                                Height="40"
                                                HorizontalAlignment="Left"
                                                LosingFocus="OnCompositeFieldLosingFocus"
                                                Command="{x:Bind ViewModel.AddDepartmentInputCommand}"
                                                IsEnabled="{x:Bind ViewModel.CanAddDepartmentInput, Mode=OneWay}"/>
                                    </StackPanel>
                            </Grid>

                            <controls:EditableField Text="{x:Bind ViewModel.SelectedCard.JobTitle, Mode=TwoWay}"
                                                    EditStarted="OnSimpleFieldEditStarted"
                                                    PlaceholderText="Click to enter job title"
                                                    FontSize="14"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <MenuFlyoutSeparator Margin="-24,0"/>

                        <!-- Contact Group -->
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Address" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <Grid Grid.Column="1">
                                    <Border Background="Transparent"
                                            Padding="0,2"
                                            Tapped="OnDetailFieldTapped"
                                            Tag="Address"
                                            Visibility="{x:Bind ViewModel.IsEditingAddress, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}">
                                        <TextBlock Text="{x:Bind ViewModel.DetailAddressText, Mode=OneWay}" FontSize="14" TextWrapping="WrapWholeWords"/>
                                    </Border>
                                    <StackPanel x:Name="AddressEditContainer"
                                                Spacing="4"
                                                Visibility="{x:Bind ViewModel.IsEditingAddress, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{x:Bind ViewModel.SelectedCard.ZipCode, Mode=TwoWay}"
                                                     PlaceholderText="Zip code"
                                                     LosingFocus="OnCompositeFieldLosingFocus"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{x:Bind ViewModel.SelectedCard.AddressLine1, Mode=TwoWay}"
                                                     PlaceholderText="Address"
                                                     LosingFocus="OnCompositeFieldLosingFocus"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    Visibility="{x:Bind ViewModel.ZipLookupStatusMessage, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}">
                                            <ProgressRing Width="16"
                                                          Height="16"
                                                          IsActive="{x:Bind ViewModel.IsZipLookupInProgress, Mode=OneWay}"
                                                          Visibility="{x:Bind ViewModel.IsZipLookupInProgress, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                          MinWidth="0"
                                                          MinHeight="0"/>
                                            <TextBlock Text="{x:Bind ViewModel.ZipLookupStatusMessage, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="WrapWholeWords"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Telephone" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <controls:EditableField Grid.Column="1"
                                                        EditStarted="OnSimpleFieldEditStarted"
                                                        Text="{x:Bind ViewModel.SelectedCard.Tel, Mode=TwoWay}"
                                                        PlaceholderText="Click to enter telephone"
                                                        FontSize="14"
                                                        VerticalAlignment="Center"/>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Mobile" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <controls:EditableField Grid.Column="1"
                                                        EditStarted="OnSimpleFieldEditStarted"
                                                        Text="{x:Bind ViewModel.SelectedCard.Mobile, Mode=TwoWay}"
                                                        PlaceholderText="Click to enter mobile"
                                                        FontSize="14"
                                                        VerticalAlignment="Center"/>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Email" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <controls:EditableField Grid.Column="1"
                                                        EditStarted="OnSimpleFieldEditStarted"
                                                        Text="{x:Bind ViewModel.SelectedCard.Email, Mode=TwoWay}"
                                                        PlaceholderText="Click to enter email"
                                                        FontSize="14"
                                                        VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <MenuFlyoutSeparator Margin="-24,0"/>

                        <!-- Metadata Group -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Tag" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <Border Background="Transparent" Padding="0,0,24,0">
                                <ItemsRepeater ItemsSource="{x:Bind SidebarTagFlowItems, Mode=OneWay}" VerticalAlignment="Top">
                                    <ItemsRepeater.Layout>
                                        <LinedFlowLayout MinItemSpacing="8" LineSpacing="8" ItemsStretch="None"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:TagFlowItem">
                                            <Grid HorizontalAlignment="Left">
                                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Height="34"
                                                        Padding="10,0"
                                                        Visibility="{x:Bind IsAddButton, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{x:Bind Text}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="140"/>
                                                        <Button Grid.Column="1"
                                                                Tag="{x:Bind Text}"
                                                                MinWidth="20"
                                                                Height="20"
                                                                VerticalAlignment="Center"
                                                                Padding="0"
                                                                Click="OnRemoveSidebarTagClicked">
                                                            <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </Border>
                            <Button Content="+ Add tag"
                                    Click="OnAddSidebarTagClicked"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Height="34"
                                    MinWidth="100"
                                    HorizontalAlignment="Left"
                                    Padding="12,4"/>
                            <TextBlock Text="Scan Date" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,8,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Path Data="M17.75 3A3.25 3.25 0 0 1 21 6.25v11.5A3.25 3.25 0 0 1 17.75 21H6.25A3.25 3.25 0 0 1 3 17.75V6.25A3.25 3.25 0 0 1 6.25 3h11.5Zm1.75 5.5h-15v9.25c0 .966.784 1.75 1.75 1.75h11.5a1.75 1.75 0 0 0 1.75-1.75V8.5Zm-11.75 6a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm-4.25-4a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm1.5-6H6.25A1.75 1.75 0 0 0 4.5 6.25V7h15v-.75a1.75 1.75 0 0 0-1.75-1.75Z" 
                                      Stretch="Uniform" Width="16" Height="16" Fill="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.SelectedCard.ScanDate, Converter={StaticResource DateTimeToStringConverter}, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Action Bar -->
                <Border Grid.Row="2" Padding="24,16" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="EditInfoButton" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,12,0" CornerRadius="8" Click="OnEditInfoClicked">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Path Data="M21.03 2.97a3.578 3.578 0 0 1 0 5.06L9.062 20a2.25 2.25 0 0 1-.999.58l-5.116 1.395a.75.75 0 0 1-.92-.921l1.395-5.116a2.25 2.25 0 0 1 .58-.999L15.97 2.97a3.578 3.578 0 0 1 5.06 0ZM15 6.06 5.062 16a.75.75 0 0 0-.193.333l-1.05 3.85 3.85-1.05A.75.75 0 0 0 8 18.938L17.94 9 15 6.06Zm2.03-2.03-.97.97L19 7.94l.97-.97a2.079 2.079 0 0 0-2.94-2.94Z" 
                                      Stretch="Uniform" Width="16" Height="16" Fill="{Binding Foreground, ElementName=EditInfoButton}"/>
                                <TextBlock Text="Edit Info"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SidebarActionIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTipService.ToolTip="Re-run AI to update card info"
                                IsEnabled="{x:Bind ViewModel.SelectedCard.IsAiReprocessAvailable, Mode=OneWay}"
                                Click="OnAiReprocessClicked">
                            <Grid>
                                <Path Data="M6 3.5h1v6.238c0 .375-.094.744-.273 1.074l-3.584 6.603A1.75 1.75 0 0 0 4.68 20h6.734l.106-.423c.096-.383.252-.746.461-1.077H4.681a.25.25 0 0 1-.22-.37l1.97-3.63h7.137l.805 1.482 1.106-1.106-2.206-4.064A2.25 2.25 0 0 1 13 9.738V3.5h1A.75.75 0 0 0 14 2H6a.75.75 0 0 0 0 1.5Zm2.5 6.238V3.5h3v6.238c0 .625.156 1.24.454 1.79l.8 1.472H7.246l.8-1.473A3.75 3.75 0 0 0 8.5 9.738Zm10.6 2.931-5.903 5.903a2.686 2.686 0 0 0-.706 1.247l-.458 1.831a1.087 1.087 0 0 0 1.319 1.318l1.83-.457a2.685 2.685 0 0 0 1.248-.707l5.902-5.902A2.286 2.286 0 0 0 19.1 12.67Z"
                                      Stretch="Uniform" Width="16" Height="16" Fill="{StaticResource BrandBlueBrush}"
                                      Visibility="{x:Bind ViewModel.SelectedCard.IsRecognizing, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"/>
                                <ProgressRing Width="16" Height="16" IsActive="True" Foreground="{StaticResource BrandBlueBrush}"
                                              Visibility="{x:Bind ViewModel.SelectedCard.IsRecognizing, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                              MinHeight="0" MinWidth="0" BorderThickness="1.5"/>
                            </Grid>
                        </Button>
                        <Button x:Name="DeleteButton" Grid.Column="2" Style="{StaticResource CriticalActionButtonStyle}" ToolTipService.ToolTip="Delete"
                                Command="{x:Bind ViewModel.DeleteCardCommand}" CommandParameter="{x:Bind ViewModel.SelectedCard, Mode=OneWay}">
                            <Path Data="M12 1.75a3.25 3.25 0 0 1 3.245 3.066L15.25 5h5.25a.75.75 0 0 1 .102 1.493L20.5 6.5h-.796l-1.28 13.02a2.75 2.75 0 0 1-2.561 2.474l-.176.006H8.313a2.75 2.75 0 0 1-2.714-2.307l-.023-.174L4.295 6.5H3.5a.75.75 0 0 1-.743-.648L2.75 5.75a.75.75 0 0 1 .648-.743L3.5 5h5.25A3.25 3.25 0 0 1 12 1.75Zm6.197 4.75H5.802l1.267 12.872a1.25 1.25 0 0 0 1.117 1.122l.127.006h7.374c.6 0 1.109-.425 1.225-1.002l.02-.126L18.196 6.5ZM13.75 9.25a.75.75 0 0 1 .743.648L14.5 10v7a.75.75 0 0 1-1.493.102L13 17v-7a.75.75 0 0 1 .75-.75Zm-3.5 0a.75.75 0 0 1 .743.648L11 10v7a.75.75 0 0 1-1.493.102L9.5 17v-7a.75.75 0 0 1 .75-.75Zm1.75-6a1.75 1.75 0 0 0-1.744 1.606L10.25 5h3.5A1.75 1.75 0 0 0 12 3.25Z" 
                                  Stretch="Uniform" Width="16" Height="16" Fill="{Binding Foreground, ElementName=DeleteButton}"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>

