<Page
    x:Class="PlustekBCR.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="28,20,32,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="26,12,0,0"
                        HorizontalAlignment="Left"
                        Spacing="14">
                <Button HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{StaticResource DetailBackButtonStyle}"
                        Click="OnBackToCardsClicked"/>

                <StackPanel Margin="48,0,0,0"
                            Spacing="6"
                            HorizontalAlignment="Left">
                    <TextBlock x:Name="SectionTitleTextBlock" Text="General" FontSize="30" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SectionDescriptionTextBlock"
                               Text="Apply language and field presentation defaults for operators working in this environment."
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
            </StackPanel>

            <Grid x:Name="GeneralContentPanel"
                  Grid.Row="1"
                  Margin="74,26,0,0"
                  MaxWidth="1260"
                  HorizontalAlignment="Left"
                  ColumnSpacing="34"
                  RowSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="642"/>
                    <ColumnDefinition Width="538"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="128"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <Border Grid.Column="0"
                        Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Border Padding="22"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Language" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Controls the default field set and import mapping used in detail, edit, and import flows."
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>

                            <ComboBox x:Name="LanguageComboBox"
                                      Width="220"
                                      SelectionChanged="OnLanguageSelectionChanged">
                                <ComboBoxItem Tag="JP" Content="Japanese"/>
                                <ComboBoxItem Tag="US" Content="English"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </Border>

                <Border Grid.Column="0"
                        Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>

                <Border Grid.Column="0"
                        Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>

                <Border Grid.Column="1"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Margin="0,58,0,0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            </Grid>

            <Border x:Name="SectionHintBorder"
                    Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="12,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="820"
                    HorizontalAlignment="Left">
                <TextBlock x:Name="SectionHintTextBlock"
                           Text="General settings are shown below."
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
