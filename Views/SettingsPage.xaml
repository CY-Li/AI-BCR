<Page
    x:Class="PlustekBCR.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="{StaticResource BcrPageOuterPadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel HorizontalAlignment="Left"
                        Spacing="14">
                <Button HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{StaticResource DetailBackButtonStyle}"
                        Click="OnBackToCardsClicked"/>

                <StackPanel Margin="{StaticResource BcrPageHeaderContentIndent}"
                            Spacing="6"
                            HorizontalAlignment="Left">
                    <TextBlock x:Name="SectionTitleTextBlock" Text="General" FontSize="30" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SectionDescriptionTextBlock"
                               Text="Apply language and field presentation defaults for operators working in this environment."
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
            </StackPanel>

            <Grid x:Name="GeneralContentPanel"
                  Grid.Row="1"
                  Margin="{StaticResource BcrPageSectionTopMargin}"
                  MaxWidth="720"
                  HorizontalAlignment="Left">
                <Border Padding="24"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Language" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Controls the default field set and import mapping used in detail, edit, and import flows."
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="WrapWholeWords"/>
                        </StackPanel>

                        <ComboBox x:Name="LanguageComboBox"
                                  Style="{StaticResource BcrComboBoxStyle}"
                                  Width="220"
                                  SelectionChanged="OnLanguageSelectionChanged">
                            <ComboBoxItem Tag="JP" Content="Japanese"/>
                            <ComboBoxItem Tag="US" Content="English"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="SectionHintBorder"
                    Grid.Row="2"
                    Margin="48,16,0,0"
                    Padding="12,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="820"
                    HorizontalAlignment="Left">
                <TextBlock x:Name="SectionHintTextBlock"
                           Text="General settings are shown below."
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
