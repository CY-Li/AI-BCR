                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                                            <Border Width="64" Height="64" CornerRadius="32" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                                <PathIcon Data="M2.747 15a.75.75 0 0 1 .743.648l.007.102v3.502l.007.128a1.25 1.25 0 0 0 1.115 1.116l.128.006h3.5l.102.007a.75.75 0 0 1 0 1.486l-.102.007h-3.5l-.167-.005a2.75 2.75 0 0 1-2.578-2.57l-.005-.175V15.75l.007-.102A.75.75 0 0 1 2.747 15Zm18.5 0a.75.75 0 0 1 .743.648l.007.102v3.502a2.75 2.75 0 0 1-2.582 2.745l-.168.005h-3.5a.75.75 0 0 1-.102-1.493l.102-.007h3.5a1.25 1.25 0 0 0 1.244-1.122l.006-.128V15.75a.75.75 0 0 1 .75-.75Zm-8.992.5a.75.75 0 0 1 .102 1.493l-.102.007H7.75a.75.75 0 0 1-.102-1.493l.102-.007h4.505Zm3.995-4.25a.75.75 0 0 1 .102 1.493l-.102.007h-8.5a.75.75 0 0 1-.102-1.493l.102-.007h8.5ZM8.247 2a.75.75 0 0 1 .102 1.493l-.102.007h-3.5a1.25 1.25 0 0 0-1.243 1.122l-.007.128v3.502a.75.75 0 0 1-1.493.102l-.007-.102V4.75A2.75 2.75 0 0 1 4.58 2.005L4.747 2h3.5Zm11 0 .168.005a2.75 2.75 0 0 1 2.577 2.57l.005.175v3.502l-.007.102a.75.75 0 0 1-1.486 0l-.007-.102V4.75l-.006-.128a1.25 1.25 0 0 0-1.116-1.116l-.128-.006h-3.5l-.102-.007a.75.75 0 0 1 0-1.486L15.747 2h3.5ZM16.25 7a.75.75 0 0 1 .102 1.493l-.102.007h-8.5a.75.75 0 0 1-.102-1.493L7.75 7h8.5Z"
                                                          Width="24"
                                                          Height="24"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="Drop back image here" FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14"/>
                                        </StackPanel>
                                    </Button>

                                    <Border x:Name="BackScanLoadingOverlay"
                                            Background="#B31C1C1C"
                                            CornerRadius="12"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                            <ProgressRing IsActive="True" Width="36" Height="36"/>
                                            <TextBlock Text="Scanning back side..."
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Bottom: Details and Notes -->
                <Grid Grid.Row="2" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Information Card -->
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="16" Padding="24">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                            <StackPanel Spacing="28">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE946;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    <TextBlock Text="Card Information" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Personal Section -->
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Personal" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" CharacterSpacing="50"/>
                                    <Grid ColumnSpacing="16" RowSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Name" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
                                            <Grid ColumnSpacing="12" Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{x:Bind ViewModel.SelectedCard.LastName, Mode=TwoWay}" PlaceholderText="Last Name"/>
                                                <TextBox Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.FirstName, Mode=TwoWay}" PlaceholderText="First Name"/>
                                            </Grid>
                                            <Grid ColumnSpacing="12" Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{x:Bind ViewModel.SelectedCard.LastNameKana, Mode=TwoWay}" PlaceholderText="Last Name Kana"/>
                                                <TextBox Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.FirstNameKana, Mode=TwoWay}" PlaceholderText="First Name Kana"/>
                                            </Grid>
                                            <Grid ColumnSpacing="12" Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{x:Bind ViewModel.SelectedCard.FirstName, Mode=TwoWay}" PlaceholderText="First Name"/>
                                                <TextBox Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.LastName, Mode=TwoWay}" PlaceholderText="Last Name"/>
                                            </Grid>
                                            <TextBox Text="{x:Bind ViewModel.SelectedCard.MiddleName, Mode=TwoWay}"
                                                     PlaceholderText="Middle Name"
                                                     Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:middle_name, Mode=OneTime}"/>
                                            <TextBox Text="{x:Bind ViewModel.SelectedCard.Suffix, Mode=TwoWay}"
                                                     PlaceholderText="Suffix"
                                                     Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:suffix, Mode=OneTime}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Text="Company" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.CompanyName, Mode=TwoWay}" PlaceholderText="Company Name"/>

                                        <TextBlock Grid.Row="2" Text="Department" VerticalAlignment="Top" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{x:Bind ViewModel.SelectedCard.Department1, Mode=TwoWay}" PlaceholderText="Department 1"/>
                                                <Button Grid.Column="1"
                                                        Content="+"
                                                        Width="36"
                                                        Height="36"
                                                        Command="{x:Bind ViewModel.AddDepartmentInputCommand}"
                                                        IsEnabled="{x:Bind ViewModel.CanAddDepartmentInput, Mode=OneWay}"/>
                                            </Grid>
                                            <TextBox Text="{x:Bind ViewModel.SelectedCard.Department2, Mode=TwoWay}" PlaceholderText="Department 2" Visibility="{x:Bind ViewModel.ShowDepartment2, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                            <TextBox Text="{x:Bind ViewModel.SelectedCard.Department3, Mode=TwoWay}" PlaceholderText="Department 3" Visibility="{x:Bind ViewModel.ShowDepartment3, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                            <TextBox Text="{x:Bind ViewModel.SelectedCard.Department4, Mode=TwoWay}" PlaceholderText="Department 4" Visibility="{x:Bind ViewModel.ShowDepartment4, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="3" Text="Job Title" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.JobTitle, Mode=TwoWay}" PlaceholderText="Job Title"/>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                                <!-- Contact Section -->
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Contact" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" CharacterSpacing="50"/>
                                    <Grid ColumnSpacing="16" RowSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Address" VerticalAlignment="Top" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
                                            <Grid ColumnSpacing="8"
                                                  Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{x:Bind ViewModel.SelectedCard.ZipCode, Mode=TwoWay}"
                                                         PlaceholderText="ZIP Code"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{x:Bind ViewModel.SelectedCard.AddressLine1, Mode=TwoWay}"
                                                         PlaceholderText="Address"/>
                                            </Grid>
                                            <StackPanel Spacing="4"
                                                        Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}">
                                                <TextBox Text="{x:Bind ViewModel.SelectedCard.AddressLine1, Mode=TwoWay}"
                                                         PlaceholderText="Address Line 1"/>
                                                <TextBox Text="{x:Bind ViewModel.SelectedCard.AddressLine2, Mode=TwoWay}"
                                                         PlaceholderText="Address Line 2"
                                                         Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:address_line_2, Mode=OneTime}"/>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="140"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{x:Bind ViewModel.SelectedCard.City, Mode=TwoWay}"
                                                             PlaceholderText="City"
                                                             Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:city, Mode=OneTime}"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{x:Bind ViewModel.SelectedCard.State, Mode=TwoWay}"
                                                             PlaceholderText="State"
                                                             Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:state, Mode=OneTime}"/>
                                                    <TextBox Grid.Column="2"
                                                             Text="{x:Bind ViewModel.SelectedCard.ZipCode, Mode=TwoWay}"
                                                             PlaceholderText="ZIP Code"/>
                                                </Grid>
                                                <TextBox Text="{x:Bind ViewModel.SelectedCard.Country, Mode=TwoWay}"
                                                         PlaceholderText="Country"
                                                         Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:country, Mode=OneTime}"/>
                                            </StackPanel>
                                            <Grid ColumnSpacing="8"
                                                  Visibility="{x:Bind ViewModel.IsJapanMarket, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{x:Bind ViewModel.SelectedCard.City, Mode=TwoWay}"
                                                         PlaceholderText="City"
                                                         Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:city, Mode=OneTime}"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{x:Bind ViewModel.SelectedCard.State, Mode=TwoWay}"
                                                         PlaceholderText="State"
                                                         Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:state, Mode=OneTime}"/>
                                            </Grid>
                                            <TextBlock Text="{x:Bind ViewModel.ZipLookupStatusMessage, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       FontSize="12"
                                                       Visibility="{x:Bind ViewModel.ZipLookupStatusMessage, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                            <ProgressRing IsActive="{x:Bind ViewModel.IsZipLookupInProgress, Mode=OneWay}"
                                                          Width="18"
                                                          Height="18"
                                                          Visibility="{x:Bind ViewModel.IsZipLookupInProgress, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Text="Telephone" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{x:Bind ViewModel.SelectedCard.Tel, Mode=TwoWay}" PlaceholderText="Telephone"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{x:Bind ViewModel.SelectedCard.Extension, Mode=TwoWay}"
                                                     PlaceholderText="Extension"
                                                     Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:extension, Mode=OneTime}"/>
                                        </Grid>

                                        <TextBlock Grid.Row="2" Text="Mobile" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:mobile, Mode=OneTime}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Mobile, Mode=TwoWay}" PlaceholderText="Mobile" Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:mobile, Mode=OneTime}"/>

                                        <TextBlock Grid.Row="3" Text="Email" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Email, Mode=TwoWay}" PlaceholderText="Email Address"/>

                                        <TextBlock Grid.Row="4" Text="Website" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:website, Mode=OneTime}"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Website, Mode=TwoWay}" PlaceholderText="Website URL" Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:website, Mode=OneTime}"/>

                                        <TextBlock Grid.Row="5" Text="Fax" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:fax, Mode=OneTime}"/>
                                        <TextBox Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Fax, Mode=TwoWay}" PlaceholderText="Fax" Visibility="{x:Bind ViewModel.CurrentMarket, Converter={StaticResource FieldVisibilityConverter}, ConverterParameter=edit:fax, Mode=OneTime}"/>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                                <!-- Metadata Section -->
                                <StackPanel Spacing="16">
                                    <Grid ColumnSpacing="16" RowSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Tag" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
                                            <Border Background="Transparent" Padding="0,0,24,0">
                                                <ItemsRepeater ItemsSource="{x:Bind EditTagFlowItems, Mode=OneWay}" VerticalAlignment="Top">
                                                    <ItemsRepeater.Layout>
                                                        <LinedFlowLayout MinItemSpacing="8" LineSpacing="8" ItemsStretch="None"/>
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="models:TagFlowItem">
                                                            <Grid HorizontalAlignment="Left">
                                                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10"
                                                                        Height="34"
                                                                        Padding="10,0"
                                                                        Visibility="{x:Bind IsAddButton, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneTime}">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{x:Bind Text}"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   MaxWidth="140"/>
                                                                        <Button Grid.Column="1"
                                                                                Tag="{x:Bind Text}"
                                                                                MinWidth="20"
                                                                                Height="20"
                                                                                VerticalAlignment="Center"
                                                                                Padding="0"
                                                                                Click="OnRemoveTagClicked">
                                                                            <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                                                        </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </Border>
                                            <Button Content="+ Add tag"
                                                    Click="OnAddTagClicked"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Height="34"
                                                    MinWidth="100"
                                                    HorizontalAlignment="Left"
                                                    Padding="12,4"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Text="Scan Date" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                            <Path Data="M17.75 3A3.25 3.25 0 0 1 21 6.25v11.5A3.25 3.25 0 0 1 17.75 21H6.25A3.25 3.25 0 0 1 3 17.75V6.25A3.25 3.25 0 0 1 6.25 3h11.5Zm1.75 5.5h-15v9.25c0 .966.784 1.75 1.75 1.75h11.5a1.75 1.75 0 0 0 1.75-1.75V8.5Zm-11.75 6a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm-4.25-4a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm4.25 0a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5Zm1.5-6H6.25A1.75 1.75 0 0 0 4.5 6.25V7h15v-.75a1.75 1.75 0 0 0-1.75-1.75Z"
                                                  Stretch="Uniform"
                                                  Width="16"
                                                  Height="16"
                                                  Fill="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind ViewModel.SelectedCard.ScanDate, Converter={StaticResource DateTimeToStringConverter}, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Right: Note (Timeline concept) -->
                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="16" Padding="24">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,24">
                                <FontIcon Glyph="&#xE70B;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                <TextBlock Text="Notes &amp; Timeline" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.SelectedCard.Notes, Mode=OneWay}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Note">
                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Timeline visual -->
                                            <Grid Grid.Column="0" Width="32" Margin="0,2,8,0">
                                                <Rectangle Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Width="2" HorizontalAlignment="Center"/>
                                                <Border Width="12" Height="12" CornerRadius="6" Background="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Top" Margin="0,4,0,0">
                                                    <Border.Shadow>
                                                        <ThemeShadow />
                                                    </Border.Shadow>
                                                </Border>
                                            </Grid>
                                            
                                            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                                    BorderThickness="1" CornerRadius="12" Padding="16">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{x:Bind CreatedAt, Converter={StaticResource DateTimeToStringConverter}}" 
                                                               FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap" FontSize="14" LineHeight="20"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            
                            <Grid Grid.Row="2" Margin="0,16,0,0" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Height="40">
                                    <TextBox x:Name="NewNoteTextBox"
                                             Text="{x:Bind ViewModel.NewNoteContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Height="40"
                                             Padding="12,8,32,8"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             TextChanged="OnNewNoteTextBoxTextChanged"
                                             KeyDown="OnNewNoteTextBoxKeyDown"/>
                                    <TextBlock x:Name="NewNotePlaceholderText"
                                               Text="Add a note..."
                                               Margin="12,0,12,0"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               IsHitTestVisible="False"/>
                                </Grid>
                                <Button Grid.Column="1" Command="{x:Bind ViewModel.AddNoteCommand}" 
                                        Style="{StaticResource AccentButtonStyle}" Width="40" Height="40" Padding="0">
                                    <FontIcon Glyph="&#xE724;" FontSize="16"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
