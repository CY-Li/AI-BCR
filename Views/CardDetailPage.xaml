                                                          Height="24"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="Drop back image here" FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14"/>
                                        </StackPanel>
                                    </Button>

                                    <Border x:Name="BackScanLoadingOverlay"
                                            Background="#B31C1C1C"
                                            CornerRadius="12"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                            <ProgressRing IsActive="True" Width="36" Height="36"/>
                                            <TextBlock Text="Scanning back side..."
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Bottom: Details and Notes -->
                <Grid Grid.Row="2" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Information Card -->
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="16" Padding="24">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                            <StackPanel Spacing="28">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE946;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    <TextBlock Text="Card Information" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Personal Section -->
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Personal" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" CharacterSpacing="50"/>
                                    <Grid ColumnSpacing="16" RowSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Name" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Name, Mode=TwoWay}" PlaceholderText="Full Name"/>

                                        <TextBlock Grid.Row="1" Text="Company" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Company, Mode=TwoWay}" PlaceholderText="Company Name"/>

                                        <TextBlock Grid.Row="2" Text="Job Title" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Title, Mode=TwoWay}" PlaceholderText="Job Title"/>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                                <!-- Contact Section -->
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Contact" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" CharacterSpacing="50"/>
                                    <Grid ColumnSpacing="16" RowSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Phone" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Phone, Mode=TwoWay}" PlaceholderText="Phone Number"/>

                                        <TextBlock Grid.Row="1" Text="Email" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Email, Mode=TwoWay}" PlaceholderText="Email Address"/>

                                        <TextBlock Grid.Row="2" Text="Website" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Website, Mode=TwoWay}" PlaceholderText="Website URL"/>

                                        <TextBlock Grid.Row="3" Text="Address" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCard.Address, Mode=TwoWay}" PlaceholderText="Physical Address" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                                <!-- Metadata Section -->
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Details" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" CharacterSpacing="50"/>
                                    <Grid ColumnSpacing="16" RowSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Scan Date" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <CalendarDatePicker Grid.Column="1" Date="{x:Bind ViewModel.SelectedCard.ScanDate, Converter={StaticResource DateTimeToDateTimeOffsetConverter}, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Right: Note (Timeline concept) -->
                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="16" Padding="24">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,24">
                                <FontIcon Glyph="&#xE70B;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                <TextBlock Text="Notes &amp; Timeline" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.SelectedCard.Notes, Mode=OneWay}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Note">
                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Timeline visual -->
                                            <Grid Grid.Column="0" Width="32" Margin="0,2,8,0">
                                                <Rectangle Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Width="2" HorizontalAlignment="Center"/>
                                                <Border Width="12" Height="12" CornerRadius="6" Background="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Top" Margin="0,4,0,0">
                                                    <Border.Shadow>
                                                        <ThemeShadow />
                                                    </Border.Shadow>
                                                </Border>
                                            </Grid>
                                            
                                            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                                    BorderThickness="1" CornerRadius="12" Padding="16">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{x:Bind CreatedAt, Converter={StaticResource DateTimeToStringConverter}}" 
                                                               FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap" FontSize="14" LineHeight="20"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            
                            <Grid Grid.Row="2" Margin="0,16,0,0" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox PlaceholderText="Add a note..." Text="{x:Bind ViewModel.NewNoteContent, Mode=TwoWay}" Height="40" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Command="{x:Bind ViewModel.AddNoteCommand}" 
                                        Style="{StaticResource AccentButtonStyle}" Width="40" Height="40" Padding="0">
                                    <FontIcon Glyph="&#xE724;" FontSize="16"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
