                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </Border>
                                            <TextBlock Text="Drop front image here" FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14"/>
                                        </StackPanel>
                                    </Button>

                                    <Border x:Name="FrontScanLoadingOverlay"
                                            Background="#B31C1C1C"
                                            CornerRadius="12"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                            <ProgressRing IsActive="True" Width="36" Height="36"/>
                                            <TextBlock Text="Scanning front side..."
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="16">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <Grid Padding="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header with Buttons -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    <TextBlock Text="Back Side" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                </StackPanel>
