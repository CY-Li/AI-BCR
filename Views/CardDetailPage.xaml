                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                    </Button>
                                    <Button Click="OnDeleteFrontClicked" ToolTipService.ToolTip="Delete front image" 
                                            Style="{StaticResource HeaderIconButtonStyle}" Width="32" Height="32" 
                                            Visibility="{x:Bind ViewModel.SelectedCard.FrontImageData, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Image Container / Empty State -->
                            <Border x:Name="FrontImageBorder" Grid.Row="1" Height="260" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12">
                                <Grid AllowDrop="True" Background="Transparent" DragEnter="OnImageDragOver" DragOver="OnImageDragOver" DragLeave="OnImageDragLeave" Drop="OnFrontImageDrop">
