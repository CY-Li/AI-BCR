<Page
    x:Class="PlustekBCR.Views.CardDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PlustekBCR.Models"
    xmlns:viewmodels="using:PlustekBCR.ViewModels"
    mc:Ignorable="d"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedCardsSource" 
                              IsSourceGrouped="True" 
                              Source="{x:Bind ViewModel.GroupedCards, Mode=OneWay}"/>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sider: Card List Thumbnails -->
        <Border Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Button x:Name="BackButton" Click="OnBackClicked" Style="{StaticResource DetailBackButtonStyle}" Margin="12,12,0,0"/>
                
                <ListView Grid.Row="1" 
                          ItemsSource="{x:Bind GroupedCardsSource.View, Mode=OneWay}"
                          SelectionMode="Single"
                          SelectedItem="{x:Bind ViewModel.SelectedCard, Mode=TwoWay}"
                          ItemContainerStyle="{StaticResource CardListViewItemStyle}"
                          Padding="0,0,0,24">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:BusinessCard">
                            <Grid Padding="8" Background="Transparent" HorizontalAlignment="Stretch">
                                <Border HorizontalAlignment="Stretch" Height="140" CornerRadius="6" 
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                        BorderThickness="1" 
                                        Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                        ToolTipService.ToolTip="{x:Bind Name}">
                                    <Image Source="{x:Bind FrontImageData, Converter={StaticResource ByteArrayToImageSourceConverter}, Mode=OneWay}" 
                                           Stretch="Uniform" Margin="8"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderContainerStyle>
                                <StaticResource ResourceKey="CardDetailListGroupHeaderItemStyle"/>
                            </GroupStyle.HeaderContainerStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate x:DataType="viewmodels:CardGroup">
                                    <TextBlock Text="{x:Bind Key}" FontSize="11" FontWeight="SemiBold" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               CharacterSpacing="50"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Padding="32" RowSpacing="24">
                <Grid.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20" IsStaggeringEnabled="True"/>
                    </TransitionCollection>
                </Grid.ChildrenTransitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header: Name and Actions -->
                    <RowDefinition Height="Auto"/> <!-- Top: Card Images -->
                    <RowDefinition Height="*"/>    <!-- Bottom: Details and Notes -->
                </Grid.RowDefinitions>

                <!-- Header: Card Name and Delete Card Action -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.SelectedCard.Name, Mode=OneWay}" FontSize="28" FontWeight="Bold"/>
                        <Border Style="{StaticResource BcrStatusPillBorderStyle}" Background="{x:Bind ViewModel.SelectedCard.Status, Converter={StaticResource StatusToBackgroundBrushConverter}, Mode=OneWay}">
                            <TextBlock Text="{x:Bind ViewModel.SelectedCard.Status, Converter={StaticResource StatusToStringConverter}, Mode=OneWay}" 
                                       Style="{StaticResource BcrStatusPillTextStyle}"
                                       Foreground="{x:Bind ViewModel.SelectedCard.Status, Converter={StaticResource StatusToForegroundBrushConverter}, Mode=OneWay}"
                                       />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Style="{StaticResource HeaderActionIconButtonStyle}"
                                ToolTipService.ToolTip="Re-run AI to update card info"
                                IsEnabled="{x:Bind ViewModel.SelectedCard.IsAiReprocessAvailable, Mode=OneWay}"
                                Click="OnAiReprocessClicked">
                            <Grid>
                                <Path Data="M6 3.5h1v6.238c0 .375-.094.744-.273 1.074l-3.584 6.603A1.75 1.75 0 0 0 4.68 20h6.734l.106-.423c.096-.383.252-.746.461-1.077H4.681a.25.25 0 0 1-.22-.37l1.97-3.63h7.137l.805 1.482 1.106-1.106-2.206-4.064A2.25 2.25 0 0 1 13 9.738V3.5h1A.75.75 0 0 0 14 2H6a.75.75 0 0 0 0 1.5Zm2.5 6.238V3.5h3v6.238c0 .625.156 1.24.454 1.79l.8 1.472H7.246l.8-1.473A3.75 3.75 0 0 0 8.5 9.738Zm10.6 2.931-5.903 5.903a2.686 2.686 0 0 0-.706 1.247l-.458 1.831a1.087 1.087 0 0 0 1.319 1.318l1.83-.457a2.685 2.685 0 0 0 1.248-.707l5.902-5.902A2.286 2.286 0 0 0 19.1 12.67Z"
                                      Stretch="Uniform"
                                      Width="18"
                                      Height="18"
                                      Fill="{StaticResource BrandBlueBrush}"
                                      Visibility="{x:Bind ViewModel.SelectedCard.IsRecognizing, Converter={StaticResource InvertedBoolToVisibilityConverter}, Mode=OneWay}"/>
                                <ProgressRing IsActive="True"
                                              Width="18"
                                              Height="18"
                                              Foreground="{StaticResource BrandBlueBrush}"
                                              Visibility="{x:Bind ViewModel.SelectedCard.IsRecognizing, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                              MinHeight="0"
                                              MinWidth="0"
                                              BorderThickness="1.5"/>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource HeaderActionIconButtonStyle}"
                                ToolTipService.ToolTip="Delete Card"
                                Command="{x:Bind ViewModel.DeleteCardCommand}"
                                CommandParameter="{x:Bind ViewModel.SelectedCard, Mode=OneWay}">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Top: Front and Back Thumbnails -->
                <Grid Grid.Row="1" ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="16">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <Grid Padding="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header with Buttons -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                    <TextBlock Text="Front Side" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <Button ToolTipService.ToolTip="Add front image" 
                                            Style="{StaticResource HeaderIconButtonStyle}" Width="32" Height="32" 
                                            Visibility="{x:Bind ViewModel.SelectedCard.FrontImageData, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Upload from file" Click="OnUploadFrontFileClicked">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE710;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="Scan from scanner" Click="OnScanFrontClicked">
