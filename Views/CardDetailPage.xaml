                                            Style="{StaticResource HeaderIconButtonStyle}" Width="32" Height="32" 
                                            Visibility="{x:Bind ViewModel.SelectedCard.BackImageData, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
