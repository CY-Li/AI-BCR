<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="BcrOverlayScrimStyle" TargetType="Grid">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#80212A36"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BcrAutoScanOverlayPanelStyle" TargetType="Border">
        <Setter Property="Width" Value="660"/>
        <Setter Property="MaxWidth" Value="760"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="{StaticResource BcrRadius.Overlay}"/>
        <Setter Property="Background" Value="{ThemeResource AppBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="BcrSearchDropdownPanelStyle" TargetType="Border">
        <Setter Property="Padding" Value="14"/>
        <Setter Property="CornerRadius" Value="{StaticResource BcrRadius.Control}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
    </Style>

    <Style x:Key="BcrImportDialogPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource BcrRadius.Overlay}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="BcrTagMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{StaticResource BcrBrush.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BcrBrush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource BcrRadius.Control}"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <Style x:Key="BcrImportLoadingShieldStyle" TargetType="Grid">
        <Setter Property="Background" Value="{ThemeResource ApplicationPageBackgroundThemeBrush}"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="CornerRadius" Value="{StaticResource BcrRadius.DropZone}"/>
    </Style>

    <Style x:Key="BcrImportDropZoneStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="{StaticResource BcrRadius.DropZone}"/>
        <Setter Property="Margin" Value="4,8"/>
        <Setter Property="AllowDrop" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    </Style>

    <Style x:Key="StopAutoScanButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{ThemeResource SystemFillColorCriticalBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource BcrRadius.Panel}"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="MinWidth" Value="160"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontSize" Value="{StaticResource BcrFontSize.Body}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="#12D92D20"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="#D92D20"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="#22D92D20"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="#B42318"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled"/>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
