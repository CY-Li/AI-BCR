<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Global Font -->
    <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/Inter.ttf#Inter, Segoe UI Variable, Segoe UI, sans-serif</FontFamily>

    <!-- BCR Design System Typography -->
    <FontFamily x:Key="BcrFontFamily.Primary">ms-appx:///Assets/Fonts/Inter.ttf#Inter, Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    <x:Double x:Key="BcrFontSize.Caption">11</x:Double>
    <x:Double x:Key="BcrFontSize.Label">12</x:Double>
    <x:Double x:Key="BcrFontSize.Body">14</x:Double>
    <x:Double x:Key="BcrFontSize.SectionTitle">16</x:Double>
    <x:Double x:Key="BcrFontSize.PageTitle">24</x:Double>
    <x:Double x:Key="BcrFontSize.WorkflowStatus">36</x:Double>
</ResourceDictionary>
